        <mxCell id="mP9hVKK-KknbQ29JO7BW-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="1. Users should be able to register and login to the platform." vertex="1">
