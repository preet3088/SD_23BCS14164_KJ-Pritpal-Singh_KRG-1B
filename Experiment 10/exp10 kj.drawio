        <mxCell id="mP9hVKK-KknbQ29JO7BW-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="2. Users (ROLE_USER &amp; ROLE_ADMIN) should be able to browse all cars and view individual car details with reviews." vertex="1">
          <mxGeometry height="26" width="730" x="360" y="382" as="geometry" />
        </mxCell>
        <mxCell id="mP9hVKK-KknbQ29JO7BW-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="3. Authenticated users should be able to submit a review for a car, along with multi-category ratings (Performance, Comfort, Mileage, etc.)." vertex="1">
          <mxGeometry height="26" width="730" x="360" y="410" as="geometry" />
        </mxCell>
        <mxCell id="mP9hVKK-KknbQ29JO7BW-7" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="4. The system should automatically calculate and update the average rating of a car after every new review." vertex="1">
