        <mxCell id="mP9hVKK-KknbQ29JO7BW-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="A web platform where users can browse cars, write reviews, and rate them across multiple categories (Performance, Comfort, Mileage, etc.)." vertex="1">
