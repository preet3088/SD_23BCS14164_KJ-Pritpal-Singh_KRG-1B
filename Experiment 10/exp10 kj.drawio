        </mxCell>
        <mxCell id="mP9hVKK-KknbQ29JO7BW-8" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;" value="5. Admin users (ROLE_ADMIN) should be able to add, update, and delete cars from the platform." vertex="1">
