      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="iatBHZA9wdZDSu2KQH9e-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Design a Whatsapp system with proper following requirements:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;1.User Service&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;2.Chat Service&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;3.Group Service&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Optimize the chat service for handling the millions of request.&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Specify the type of connection used in the design.&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;determine how the desing will be done for last seen functionality&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Implement cdc Pipeline in the same architecture.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="360" x="200" y="80" as="geometry" />
        </mxCell>
        <mxCell id="iatBHZA9wdZDSu2KQH9e-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Functional Requirements:&lt;/span&gt;&lt;br&gt;&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;User should be able to create and login accounts.&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;User should be able to chat and connect with people.&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;User should be able to create group chat conversations.&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;User should be able to see message delivery status ie(delivered ,seen)&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="440" x="200" y="250" as="geometry" />
        </mxCell>
        <mxCell id="iatBHZA9wdZDSu2KQH9e-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Non Functional Requirements&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;System should have latency of ~200 ms.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;System should be able to handle 1 million QPS&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="440" x="200" y="420" as="geometry" />
        </mxCell>
